{
  "name": "@baremetallabs-ai/shipper-core",
  "version": "3.0.1",
  "description": "Core domain logic for Shipper workflow orchestration",
  "keywords": [
    "shipper",
    "workflow",
    "github",
    "coding-agents"
  ],
  "homepage": "https://shipper.baremetallabs.ai",
  "bugs": {
    "url": "https://github.com/baremetallabs-ai/shipper/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/baremetallabs-ai/shipper.git"
  },
  "author": "Bare Metal Labs AI",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.5",
    "vitest": "^3.0.5"
  },
  "files": [
    "dist"
  ]
}
