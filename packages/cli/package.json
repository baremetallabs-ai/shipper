{
  "name": "@baremetallabs-ai/shipper-cli",
  "version": "3.1.0",
  "description": "CLI workflow orchestrator for GitHub issues using coding agents",
  "homepage": "https://shipper.baremetallabs.ai",
  "bugs": {
    "url": "https://github.com/baremetallabs-ai/shipper/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/baremetallabs-ai/shipper.git"
  },
  "author": "Bare Metal Labs AI",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "bin": {
    "shipper": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx --loader ./raw-text-loader.mjs src/index.ts",
    "build": "npm --prefix ../core run build && tsup",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "docs:generate-cli": "npm --prefix ../core run build && tsx --loader ./raw-text-loader.mjs scripts/generate-cli-reference.ts",
    "docs:check-cli": "npm --prefix ../core run build && tsx --loader ./raw-text-loader.mjs scripts/generate-cli-reference.ts --check",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "cli",
    "github",
    "workflow",
    "coding-agents",
    "issue-lifecycle",
    "developer-tools"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@baremetallabs-ai/shipper-core": "3.1.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  }
}
