{
  "name": "@dnsquared/shipper-mcp",
  "version": "2.0.0",
  "description": "MCP server for Shipper workflow orchestration",
  "repository": {
    "type": "git",
    "url": "https://github.com/dnsquared/shipper-cli.git"
  },
  "private": true,
  "type": "module",
  "bin": {
    "shipper-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx --loader ./raw-text-loader.mjs src/index.ts",
    "build": "npm --prefix ../core run build && tsup",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@dnsquared/shipper-core": "2.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@vitest/coverage-v8": "^3.0.5",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "~6.0.3",
    "vitest": "^3.0.5"
  }
}
