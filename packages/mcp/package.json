{
  "name": "@baremetallabs-ai/shipper-mcp",
  "version": "3.1.0",
  "description": "MCP server for Shipper workflow orchestration",
  "homepage": "https://shipper.baremetallabs.ai",
  "bugs": {
    "url": "https://github.com/baremetallabs-ai/shipper/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/baremetallabs-ai/shipper.git"
  },
  "author": "Bare Metal Labs AI",
  "private": true,
  "type": "module",
  "bin": {
    "shipper-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx --loader ./raw-text-loader.mjs src/index.ts",
    "build": "npm --prefix ../core run build && tsup && node scripts/copy-docs-snapshot.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "docs:generate-mcp": "npm --prefix ../core run build && tsx --loader ./raw-text-loader.mjs scripts/generate-mcp-reference.ts",
    "docs:check-mcp": "npm --prefix ../core run build && tsx --loader ./raw-text-loader.mjs scripts/generate-mcp-reference.ts --check",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@baremetallabs-ai/shipper-core": "3.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  }
}
