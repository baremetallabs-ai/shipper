{
  "prReviewWait": {
    "mode": "timer",
    "timeoutMinutes": 15
  },
  "lockTimeoutMinutes": 30,
  "agentTimeoutMinutes": 60,
  "commands": {
    "default": {
      "agent": "claude"
    },
    "implement": {
      "agent": "codex"
    },
    "pr_remediate": {
      "agent": "codex"
    },
    "plan": {
      "agent": "codex"
    }
  },
  "merge": {
    "requirePassingChecks": true
  },
  "cliVersion": "1.0.0"
}
